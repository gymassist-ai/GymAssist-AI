# AI provider
# auto = Groq first, OpenAI fallback, Gemini fallback. You can also set groq, openai, or gemini.
AI_PROVIDER="auto"

# GroqCloud API - primary AI provider
GROQ_API_KEY="YOUR_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"
# Optional override for Groq's OpenAI-compatible endpoint.
GROQ_BASE_URL="https://api.groq.com/openai/v1"

# OpenAI API
# Kept as backup when Groq is unavailable.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"

# Gemini API
# Kept as backup when Groq/OpenAI are unavailable.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3-flash-preview"

# App URL
APP_URL="YOUR_APP_URL"

# Supabase credentials
SUPABASE_URL="YOUR_SUPABASE_URL"

# Production/server-only key. Use this on Vercel for custom table reads.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Server-only token signing secret for legacy dashboard sessions.
AUTH_SESSION_SECRET="YOUR_LONG_RANDOM_SECRET"
JWT_SECRET="YOUR_LONG_RANDOM_JWT_SECRET"
SESSION_SECRET="YOUR_LONG_RANDOM_SESSION_SECRET"

# Optional public Supabase key for non-secret browser flows. Never use it for protected auth.
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
